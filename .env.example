# ═══════════════════════════════════════════════════════════
# Bountr — Environment Variables
# Copy to .env and fill in your values before running.
# ═══════════════════════════════════════════════════════════

# ── Database ─────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bountr

# ── x402 Payments ────────────────────────────────────────────
# Solana wallet address that receives USDC payments
# Generate one with: solana-keygen new --outfile wallet.json
PAYMENT_ADDRESS=YourSolanaWalletAddressHere

# Facilitator URL (Coinbase CDP — requires account: https://portal.cdp.coinbase.com)
X402_FACILITATOR_URL=https://api.cdp.coinbase.com/platform/v2/x402

# CAIP-2 network identifier — Solana mainnet
X402_NETWORK=solana:5eykt4UsFv8P8NJdTREpY1vzqKqZKvdp

# ── AI Classification ─────────────────────────────────────────
# OpenAI API key for bounty classification (gpt-4o-mini)
# Get one at: https://platform.openai.com
OPENAI_API_KEY=sk-proj-...

# ── API Server ────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Worker ────────────────────────────────────────────────────
# Set to "true" to disable actual scraping (for local dev / CI)
SCRAPER_DRY_RUN=false

# How often to poll go.pump.fun (seconds, minimum 30 to be polite)
SCRAPER_INTERVAL_SECONDS=60

# Optional: custom Solana RPC endpoint (defaults to public)
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
