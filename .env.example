# ═══════════════════════════════════════════════════════════
# Agent GO — Environment Variables
# Copy to .env and fill in your values before running.
# ═══════════════════════════════════════════════════════════

# ── Database ─────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agentgo

# ── x402 Payments ────────────────────────────────────────────
# Solana wallet address that receives USDC payments
# Generate one with: solana-keygen new --outfile wallet.json
PAYMENT_ADDRESS=YourSolanaWalletAddressHere

# Facilitator URL:
#   • Devnet testing  → https://x402.org/facilitator
#   • Solana mainnet  → https://api.cdp.coinbase.com/platform/v2/x402
#     (requires Coinbase CDP account: https://portal.cdp.coinbase.com)
X402_FACILITATOR_URL=https://x402.org/facilitator

# CAIP-2 network identifier:
#   • Devnet   → solana:EtWTRABZaYq6iMfeYKouRu166VU2xqa1
#   • Mainnet  → solana:5eykt4UsFv8P8NJdTREpY1vzqKqZKvdp
X402_NETWORK=solana:EtWTRABZaYq6iMfeYKouRu166VU2xqa1

# ── AI Classification ─────────────────────────────────────────
# Anthropic API key for bounty classification (claude-sonnet-4-6)
# Get one at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── API Server ────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Worker ────────────────────────────────────────────────────
# Set to "true" to disable actual scraping (for local dev / CI)
SCRAPER_DRY_RUN=false

# How often to poll go.pump.fun (seconds, minimum 30 to be polite)
SCRAPER_INTERVAL_SECONDS=60

# Optional: custom Solana RPC endpoint (defaults to public)
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
