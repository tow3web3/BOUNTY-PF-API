{
  "buildCommand": "(cd packages/shared && npm run build) && cd apps/web && npx vite build",
  "outputDirectory": "apps/web/dist",
  "installCommand": "npm install",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/v1/(.*)", "destination": "/api/index" }
  ]
}
